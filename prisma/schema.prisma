// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shopify session table - must match exactly what the PrismaSessionStorage expects
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String?   // Must be optional for offline sessions
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken  String?   // Required for token rotation
  refreshTokenExpires DateTime?
  
  // Additional fields that might be needed
  onlineAccessInfo Json?   // For online session metadata
  
  // Indexes for performance
  @@index([shop])
  @@index([isOnline])
  @@index([expires])  // For cleaning up expired sessions
}


// prisma/schema.prisma

model LiveSession {
  id         Int      @id @default(autoincrement())
  shop       String
  streamId   String
  productIds String   // store as JSON string or CSV
  createdAt  DateTime @default(now())

  @@index([shop])
  @@index([streamId])
}