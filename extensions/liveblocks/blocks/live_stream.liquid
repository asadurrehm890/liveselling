{% doc %}
  Renders an embedded live stream frontend inside an iframe.

  The iframe points to the external viewer frontend URL that shows
  the current live stream link for the shop.

  @example
  {% content_for 'block', type: 'live_stream', id: 'live_stream' %}
{% enddoc %}

<div class="live-stream-embed-block" style="--live-stream-height: {{ block.settings.height }}px">
  <iframe
    src="https://liveselling-eta.vercel.app/viewerfrontend"
    title="Live stream viewer"
    loading="lazy"
    allowfullscreen
    referrerpolicy="no-referrer-when-downgrade"
    class="live-stream-embed-iframe"
  ></iframe>
</div>

{% style %}
  .live-stream-embed-block {
    margin: 10px 0;
    width: 100%;
  }

  .live-stream-embed-iframe {
    width: 100%;
    min-height: var(--live-stream-height, 600px);
    border: none;
    border-radius: 8px;
    overflow: hidden;
  }

  @media (max-width: 749px) {
    .live-stream-embed-iframe {
      min-height: calc(var(--live-stream-height, 600px) - 100px);
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Live stream embed",
  "settings": [
    {
      "type": "range",
      "id": "height",
      "label": "Iframe height (px)",
      "min": 400,
      "max": 1200,
      "step": 50,
      "default": 600
    }
  ]
}
{% endschema %}